# ==========================================
# OPENCLAW STOCK AGENT - ENVIRONMENT CONFIG
# ==========================================

# 1. 大模型智脑配置 (LLM Providers)
LLM_API_KEY=your_generic_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# 2. 泛网络与社媒情报搜刮 (Web Search & Intelligence)
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here
DESEARCH_API_KEY=your_desearch_api_key_here

# 3. 结构化金融数据 (Financial Data & SEC)
FMP_API_KEY=your_fmp_api_key_here

# 4. Agent 轮询与运行配置 (Runtime Configuration)
POLL_INTERVAL_MS=300000 # 5分钟轮询一次
LOG_LEVEL=info
