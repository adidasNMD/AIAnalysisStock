# ==========================================
# Sineige Alpha Intelligence Engine
# Monorepo .gitignore
# ==========================================

# === Secrets & Environment ===
.env
.env.local
.env.production
config/.env
!config/.env.example

# === Node.js ===
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Python ===
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.tox/
.mypy_cache/
*.egg-info/
*.egg

# === Golang ===
microservices/go_daemon/go_daemon_bin

# === Vendors (git submodules) ===
# Submodule content is tracked by git, but their build artifacts are not
vendors/*/node_modules/
vendors/*/.venv/
vendors/*/venv/
vendors/*/__pycache__/
vendors/*/dist/
vendors/*/build/
vendors/*/*.egg-info/
vendors/openbb/.venv/
vendors/trendradar/.venv/
vendors/trading-agents/.venv/

# === Data & Output (runtime, not source) ===
out/
data/*.db
data/*.db-journal
data/*.db-wal

# === OS Files ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# === IDE ===
.idea/
*.iml

# === Temporary ===
tmp_*.ts
*.tmp
*.bak
.specstory
