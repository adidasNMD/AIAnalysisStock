{
  "name": "aianalysisstock",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "ts-node -O '{\"verbatimModuleSyntax\": false}' src/index.ts",
    "server": "ts-node -O '{\"verbatimModuleSyntax\": false}' src/server/index.ts",
    "daemon": "ts-node -O '{\"verbatimModuleSyntax\": false}' src/daemon/index.ts",
    "daemon:all": "ts-node -O '{\"verbatimModuleSyntax\": false}' src/worker.ts",
    "dev:server": "node --watch -r ts-node/register/transpile-only src/server/index.ts",
    "dev:daemon": "node --watch -r ts-node/register/transpile-only src/daemon/index.ts",
    "dev:dashboard": "npm --prefix dashboard run dev -- --host 127.0.0.1 --port 5173",
    "dev:stack": "bash ./scripts/dev-stack.sh",
    "dev:stack:no-vendors": "DEV_START_VENDORS=0 bash ./scripts/dev-stack.sh",
    "check:dev-env": "bash ./scripts/check-dev-env.sh",
    "typecheck": "tsc --noEmit -p tsconfig.core.json && tsc --noEmit -p dashboard/tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "openclaw": "^2026.3.22",
    "rss-parser": "^3.13.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0",
    "yahoo-finance2": "^3.13.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  }
}
