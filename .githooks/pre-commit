#!/bin/sh
# TypeScript type check (ignore dashboard/ React errors — known pre-existing)
NODE_OPTIONS="--max-old-space-size=8192" npx tsc --noEmit 2>&1 | grep -v "dashboard/" || true
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed"
  exit 1
fi
# Run tests
NODE_OPTIONS="--max-old-space-size=8192" npx vitest run --reporter=dot
if [ $? -ne 0 ]; then
  echo "❌ Tests failed"
  exit 1
fi
