# ==========================================
# Sineige Alpha Intelligence Engine
# Environment Configuration Template
# ==========================================
# Copy this to config/.env and fill in your values

# 1. LLM Provider (主力大模型)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4/
LLM_MODEL=GLM-5.1
ZHIPUAI_API_KEY=your_llm_api_key_here
AI_API_KEY=your_llm_api_key_here

# 2. Web Search & Intelligence (网络情报)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here
DESEARCH_API_KEY=your_desearch_api_key_here

# 3. Financial Data (金融数据)
FMP_API_KEY=your_fmp_api_key_here

# 4. Runtime Configuration (运行时配置)
POLL_INTERVAL_MS=300000
LOG_LEVEL=info
MOCK_LLM=false

# 5. Telegram Push Alerts (推送通知)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 6. Service URLs (服务地址, Docker 模式下需修改)
OPENBB_API_URL=http://localhost:8000
TRADING_AGENTS_URL=http://localhost:8001
